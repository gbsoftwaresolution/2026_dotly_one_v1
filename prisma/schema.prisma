generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum QrType {
  profile
  quick_connect
}

enum QrStatus {
  active
  expired
  disabled
}

enum PersonaType {
  PERSONAL     @map("personal")
  PROFESSIONAL @map("professional")
  BUSINESS     @map("business")
}

enum PersonaAccessMode {
  OPEN    @map("open")
  REQUEST @map("request")
  PRIVATE @map("private")
}

enum PersonaSocialLinksDisplayMode {
  BUTTONS  @map("buttons")
  ICONS    @map("icons")
}

enum PersonaSharingMode {
  CONTROLLED @map("controlled")
  SMART_CARD @map("smart_card")
}

enum ContactRequestSourceType {
  PROFILE @map("profile")
  QR      @map("qr")
  EVENT   @map("event")
}

enum EventStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  LIVE      @map("live")
  ENDED     @map("ended")
}

enum EventParticipantRole {
  ATTENDEE  @map("attendee")
  SPEAKER   @map("speaker")
  ORGANIZER @map("organizer")
}

enum ContactRequestStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")
}

enum ContactRelationshipState {
  INSTANT_ACCESS @map("instant_access")
  APPROVED @map("approved")
  EXPIRED        @map("expired")
}

enum RelationshipConnectionSource {
  QR      @map("qr")
  EVENT   @map("event")
  MANUAL  @map("manual")
  UNKNOWN @map("unknown")
}

enum InteractionType {
  GREETING
  FOLLOW_UP
  THANK_YOU
}

enum FollowUpStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

enum FollowUpType {
  MANUAL         @map("manual")
  INACTIVITY     @map("inactivity")
  EVENT_FOLLOWUP @map("event_followup")
}

enum AgencyProfileStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
}

enum SupportRequestStatus {
  OPEN     @map("open")
  RESOLVED @map("resolved")
}

enum SupportDeliveryStatus {
  SENT   @map("sent")
  LOGGED @map("logged")
  FAILED @map("failed")
}

enum NotificationType {
  REQUEST_RECEIVED @map("request_received")
  REQUEST_APPROVED @map("request_approved")
  INSTANT_CONNECT  @map("instant_connect")
  EVENT_JOINED     @map("event_joined")
  EVENT_REQUEST    @map("event_request")
  SYSTEM           @map("system")
}

enum AnalyticsEventType {
  PROFILE_VIEW    @map("profile_view")
  QR_SCAN         @map("qr_scan")
  REQUEST_SENT    @map("request_sent")
  REQUEST_APPROVED @map("request_approved")
  CONTACT_CREATED @map("contact_created")
  EMAIL_VERIFICATION_ISSUED @map("email_verification_issued")
  EMAIL_VERIFICATION_VERIFIED @map("email_verification_verified")
  EMAIL_VERIFICATION_RESENT @map("email_verification_resent")
  VERIFICATION_REQUIREMENT_BLOCKED @map("verification_requirement_blocked")
}

enum MobileOtpPurpose {
  ENROLLMENT @map("enrollment")
}

enum IdentityType {
  PERSONAL     @map("personal")
  PROFESSIONAL @map("professional")
  BUSINESS     @map("business")
  COUPLE       @map("couple")
  FAMILY       @map("family")
}

enum ConnectionType {
  UNKNOWN           @map("unknown")
  REQUESTED         @map("requested")
  KNOWN             @map("known")
  TRUSTED           @map("trusted")
  INNER_CIRCLE      @map("inner_circle")
  FAMILY            @map("family")
  PARTNER           @map("partner")
  COLLEAGUE         @map("colleague")
  CLIENT            @map("client")
  VENDOR            @map("vendor")
  VERIFIED_BUSINESS @map("verified_business")
  ADMIN_MANAGED     @map("admin_managed")
  BLOCKED           @map("blocked")
  SUSPENDED_RISKY   @map("suspended_risky")
}

enum RelationshipType {
  UNKNOWN                   @map("unknown")
  FRIEND                    @map("friend")
  PARTNER                   @map("partner")
  FAMILY_MEMBER             @map("family_member")
  COLLEAGUE                 @map("colleague")
  CLIENT                    @map("client")
  VENDOR                    @map("vendor")
  VERIFIED_BUSINESS_CONTACT @map("verified_business_contact")
  INNER_CIRCLE              @map("inner_circle")
  HOUSEHOLD_SERVICE         @map("household_service")
  SUPPORT_AGENT             @map("support_agent")
}

enum TrustState {
  UNVERIFIED      @map("unverified")
  BASIC_VERIFIED  @map("basic_verified")
  STRONG_VERIFIED @map("strong_verified")
  TRUSTED_BY_USER @map("trusted_by_user")
  HIGH_RISK       @map("high_risk")
  RESTRICTED      @map("restricted")
  BLOCKED         @map("blocked")
}

enum ConnectionStatus {
  PENDING    @map("pending")
  ACTIVE     @map("active")
  RESTRICTED @map("restricted")
  BLOCKED    @map("blocked")
  ARCHIVED   @map("archived")
}

enum PermissionEffect {
  ALLOW              @map("allow")
  DENY               @map("deny")
  REQUEST_APPROVAL   @map("request_approval")
  ALLOW_WITH_LIMITS  @map("allow_with_limits")
}

model User {
  id                      String                @id @default(uuid()) @db.Uuid
  email                   String                @unique
  referralCode            String                @unique @db.VarChar(24)
  referredBy              String?               @db.Uuid
  passwordHash            String
  lastUsedPersonaId       String?               @db.Uuid
  isVerified              Boolean               @default(false)
  phoneNumber             String?               @unique @db.VarChar(32)
  pendingPhoneNumber      String?               @db.VarChar(32)
  phoneVerifiedAt         DateTime?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mobileOtpChallenges     MobileOtpChallenge[]
  authSessions            AuthSession[]
  personas                Persona[]
  referrer                User?                 @relation("UserReferrals", fields: [referredBy], references: [id], onDelete: SetNull)
  referrals               User[]                @relation("UserReferrals")
  ownedAgencyProfiles     AgencyProfile[]
  analyticsEvents         AnalyticsEvent[]
  createdEvents           Event[]
  eventParticipants       EventParticipant[]
  sentInteractions        Interaction[]
  outgoingContactRequests ContactRequest[]      @relation("ContactRequestFromUser")
  incomingContactRequests ContactRequest[]      @relation("ContactRequestToUser")
  ownedRelationships      ContactRelationship[] @relation("ContactRelationshipOwnerUser")
  targetRelationships     ContactRelationship[] @relation("ContactRelationshipTargetUser")
  followUps               FollowUp[]
  initiatedBlocks         Block[]               @relation("BlockerUser")
  receivedBlocks          Block[]               @relation("BlockedUser")
  notifications           Notification[]
  resolvedSupportRequests SupportRequest[]      @relation("SupportRequestResolvedByUser")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([referredBy])
  @@index([lastUsedPersonaId])
}

model AgencyProfile {
  id          String              @id @default(uuid()) @db.Uuid
  ownerUserId String              @db.Uuid
  name        String              @db.VarChar(160)
  // Slugs are stored as canonical lowercase values.
  slug        String              @unique @db.VarChar(80)
  tagline     String?             @db.VarChar(160)
  description String?             @db.Text
  logoUrl     String?             @db.VarChar(500)
  status      AgencyProfileStatus @default(DRAFT)
  ownerUser   User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  personas    Persona[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([ownerUserId, createdAt])
  @@index([status, updatedAt])
}

model EmailVerificationToken {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  tokenHash    String   @unique @db.VarChar(64)
  expiresAt    DateTime
  consumedAt   DateTime?
  supersededAt DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([userId, consumedAt, supersededAt, expiresAt])
  @@index([consumedAt])
  @@index([supersededAt])
}

model PasswordResetToken {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  tokenHash    String   @unique @db.VarChar(64)
  expiresAt    DateTime
  consumedAt   DateTime?
  supersededAt DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([userId, consumedAt, supersededAt, expiresAt])
  @@index([consumedAt])
  @@index([supersededAt])
}

model MobileOtpChallenge {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @db.Uuid
  phoneNumber         String           @db.VarChar(32)
  purpose             MobileOtpPurpose @default(ENROLLMENT)
  codeHash            String           @db.VarChar(64)
  expiresAt           DateTime
  consumedAt          DateTime?
  supersededAt        DateTime?
  invalidAttemptCount Int              @default(0)
  lastAttemptAt       DateTime?
  resendAvailableAt   DateTime
  createdAt           DateTime         @default(now())
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([userId, phoneNumber, createdAt])
  @@index([userId, purpose, consumedAt, supersededAt, expiresAt])
  @@index([consumedAt])
  @@index([supersededAt])
}

model AuthSession {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  userAgent     String?  @db.VarChar(512)
  deviceLabel   String   @db.VarChar(160)
  platformLabel String   @db.VarChar(80)
  ipAddressHash String?  @db.VarChar(64)
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?  @db.VarChar(120)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt, expiresAt, lastActiveAt])
}

model Persona {
  id                       String                @id @default(uuid()) @db.Uuid
  userId                   String                @db.Uuid
  identityId               String                @db.Uuid
  agencyProfileId          String?               @db.Uuid
  type                     PersonaType
  isPrimary                Boolean               @default(false)
  username                 String                @unique
  publicUrl                String                @unique
  fullName                 String
  jobTitle                 String
  companyName              String?
  tagline                  String?
  websiteUrl               String?               @db.VarChar(500)
  isVerified               Boolean               @default(false)
  profilePhotoUrl          String?
  accessMode               PersonaAccessMode
  verifiedOnly             Boolean               @default(false)
  emailVerified            Boolean               @default(false)
  phoneVerified            Boolean               @default(false)
  businessVerified         Boolean               @default(false)
  trustScore               Int?
  sharingMode              PersonaSharingMode    @default(CONTROLLED)
  smartCardConfig          Json?
  routingKey               String?               @db.VarChar(64)
  routingDisplayName       String?               @db.VarChar(160)
  isDefaultRouting         Boolean               @default(false)
  routingRulesJson         Json?
  publicPhone              String?               @db.VarChar(32)
  publicWhatsappNumber     String?               @db.VarChar(32)
  publicEmail              String?               @db.VarChar(254)
  locationAddress          String?               @db.VarChar(200)
  locationMapUrl           String?               @db.VarChar(500)
  socialLinks              Json?
  socialLinksDisplayMode   PersonaSocialLinksDisplayMode @default(BUTTONS)
  agencyProfile            AgencyProfile?        @relation(fields: [agencyProfileId], references: [id], onDelete: SetNull)
  identity                 Identity              @relation(fields: [identityId], references: [id], onDelete: Cascade)
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrAccessTokens           QRAccessToken[]
  analyticsEvents          AnalyticsEvent[]
  analytics                PersonaAnalytics?
  identityConversations    IdentityConversation[]
  memberAssignments        IdentityMemberPersonaAssignment[]
  operatorAssignments      IdentityOperatorPersonaAssignment[]
  eventParticipations      EventParticipant[]
  outgoingContactRequests  ContactRequest[]      @relation("ContactRequestFromPersona")
  incomingContactRequests  ContactRequest[]      @relation("ContactRequestToPersona")
  ownedRelationships       ContactRelationship[] @relation("ContactRelationshipOwnerPersona")
  targetRelationships      ContactRelationship[] @relation("ContactRelationshipTargetPersona")
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([agencyProfileId])
  @@index([identityId])
  @@index([userId])
  @@index([userId, isPrimary, createdAt])
  @@index([userId, updatedAt, createdAt])
  @@unique([id, userId])
  @@unique([identityId, routingKey])
}

model QRAccessToken {
  id        String   @id @default(uuid()) @db.Uuid
  personaId String   @db.Uuid
  type      QrType
  code      String   @unique
  rules     Json
  startsAt  DateTime?
  endsAt    DateTime?
  maxUses   Int?
  usedCount Int      @default(0)
  status    QrStatus @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId])
  @@index([status])
}

model Event {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @db.VarChar(160)
  slug              String             @unique @db.VarChar(160)
  description       String?            @db.Text
  startsAt          DateTime
  endsAt            DateTime
  location          String             @db.VarChar(200)
  status            EventStatus        @default(DRAFT)
  createdByUserId   String             @db.Uuid
  createdByUser     User               @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  participants      EventParticipant[]
  contactMemories   ContactMemory[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, startsAt])
  @@index([createdByUserId, createdAt])
}

model EventParticipant {
  id                String               @id @default(uuid()) @db.Uuid
  eventId           String               @db.Uuid
  userId            String               @db.Uuid
  personaId         String               @db.Uuid
  role              EventParticipantRole @default(ATTENDEE)
  discoveryEnabled  Boolean              @default(false)
  joinedAt          DateTime             @default(now())
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona           Persona              @relation(fields: [personaId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([eventId, userId])
  @@unique([eventId, personaId])
  @@index([eventId, discoveryEnabled, joinedAt])
  @@index([userId, joinedAt])
}

model ContactRequest {
  id            String               @id @default(uuid()) @db.Uuid
  fromUserId    String               @db.Uuid
  toUserId      String               @db.Uuid
  fromPersonaId String               @db.Uuid
  toPersonaId   String               @db.Uuid
  reason        String?              @db.VarChar(280)
  sourceType    ContactRequestSourceType
  sourceId      String?              @db.Uuid
  status        ContactRequestStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  respondedAt   DateTime?
  fromUser      User                 @relation("ContactRequestFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser        User                 @relation("ContactRequestToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  fromPersona   Persona              @relation("ContactRequestFromPersona", fields: [fromPersonaId, fromUserId], references: [id, userId], onDelete: Cascade)
  toPersona     Persona              @relation("ContactRequestToPersona", fields: [toPersonaId, toUserId], references: [id, userId], onDelete: Cascade)

  @@index([fromUserId, createdAt])
  @@index([toUserId, status, createdAt])
  @@index([fromPersonaId, toPersonaId, status])
  // Partial unique index for pending requests is added in SQL migration.
}

model ContactRelationship {
  id                 String                       @id @default(uuid()) @db.Uuid
  ownerUserId        String                       @db.Uuid
  targetUserId       String                       @db.Uuid
  ownerPersonaId     String                       @db.Uuid
  targetPersonaId    String                       @db.Uuid
  state              ContactRelationshipState     @default(APPROVED)
  sourceType         ContactRequestSourceType
  sourceId           String?                      @db.Uuid
  connectionContext Json?
  connectedAt        DateTime                     @default(now())
  metAt              DateTime?
  connectionSource   RelationshipConnectionSource @default(UNKNOWN)
  contextLabel       String?                      @db.VarChar(160)
  accessStartAt      DateTime?
  accessEndAt        DateTime?
  lastInteractionAt DateTime?
  interactionCount   Int                          @default(0)
  notes              String?                      @db.Text
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  ownerUser          User                         @relation("ContactRelationshipOwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  targetUser         User                         @relation("ContactRelationshipTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  ownerPersona       Persona                      @relation("ContactRelationshipOwnerPersona", fields: [ownerPersonaId, ownerUserId], references: [id, userId], onDelete: Cascade)
  targetPersona      Persona                      @relation("ContactRelationshipTargetPersona", fields: [targetPersonaId, targetUserId], references: [id, userId], onDelete: Cascade)
  memories           ContactMemory[]
  interactions       Interaction[]
  followUps          FollowUp[]

  @@unique([ownerUserId, targetUserId, ownerPersonaId, targetPersonaId])
  @@unique([id, ownerUserId])
  @@index([ownerUserId, state, accessEndAt, createdAt])
  @@index([ownerUserId, lastInteractionAt, createdAt])
  @@index([targetUserId, createdAt])
}

model Interaction {
  id             String              @id @default(uuid()) @db.Uuid
  relationshipId String              @db.Uuid
  senderUserId   String              @db.Uuid
  type           InteractionType
  payload        Json?
  createdAt      DateTime            @default(now())
  relationship   ContactRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  senderUser     User                @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([relationshipId, createdAt])
  @@index([senderUserId, createdAt])
  @@index([relationshipId, senderUserId, createdAt])
}

model FollowUp {
  id             String         @id @default(uuid()) @db.Uuid
  ownerUserId    String         @db.Uuid
  relationshipId String         @db.Uuid
  remindAt       DateTime
  triggeredAt    DateTime?
  status         FollowUpStatus @default(PENDING)
  isSystemGenerated Boolean     @default(false)
  type           FollowUpType   @default(MANUAL)
  note           String?        @db.VarChar(1000)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  completedAt    DateTime?
  ownerUser      User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  relationship   ContactRelationship @relation(fields: [relationshipId, ownerUserId], references: [id, ownerUserId], onDelete: Cascade)

  @@index([ownerUserId, status, remindAt])
  @@index([ownerUserId, status, triggeredAt, remindAt])
  @@index([relationshipId, remindAt])
  @@index([ownerUserId, updatedAt])
  @@index([relationshipId, isSystemGenerated, type, createdAt])
}

model ContactMemory {
  id             String              @id @default(uuid()) @db.Uuid
  relationshipId String              @db.Uuid
  eventId        String?             @db.Uuid
  contextLabel   String              @default("") @db.VarChar(160)
  sourceLabel    String?             @db.VarChar(120)
  metAt          DateTime
  note           String?             @db.Text
  relationship   ContactRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  event          Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([relationshipId])
  @@index([eventId])
}

model Block {
  id            String   @id @default(uuid()) @db.Uuid
  blockerUserId String   @db.Uuid
  blockedUserId String   @db.Uuid
  createdAt     DateTime @default(now())
  blockerUser   User     @relation("BlockerUser", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(120)
  body      String           @db.VarChar(280)
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
}

model SupportRequest {
  id               String                @id @default(uuid()) @db.Uuid
  referenceId      String                @unique @db.VarChar(64)
  requesterName    String?               @db.VarChar(120)
  requesterEmail   String                @db.VarChar(254)
  topic            String                @db.VarChar(80)
  details          String                @db.Text
  status           SupportRequestStatus  @default(OPEN)
  deliveryStatus   SupportDeliveryStatus @default(LOGGED)
  ipAddressHash    String?               @db.VarChar(64)
  userAgent        String?               @db.VarChar(512)
  resolvedAt       DateTime?
  resolvedByUserId String?               @db.Uuid
  resolvedByUser   User?                 @relation("SupportRequestResolvedByUser", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([requesterEmail, createdAt])
  @@index([resolvedByUserId, resolvedAt])
}

model AnalyticsEvent {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String?            @db.Uuid
  personaId String?            @db.Uuid
  eventType AnalyticsEventType
  entityId  String?            @db.Uuid
  metadata  Json?
  createdAt DateTime           @default(now())
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  persona   Persona?           @relation(fields: [personaId], references: [id], onDelete: SetNull)

  @@index([personaId, createdAt])
  @@index([eventType, createdAt])
  @@index([eventType, entityId])
  // Partial unique index for idempotent event entity keys is added in SQL migration.
}

model PersonaAnalytics {
  id               String   @id @default(uuid()) @db.Uuid
  personaId        String   @unique @db.Uuid
  profileViews     Int      @default(0)
  qrScans          Int      @default(0)
  requestsReceived Int      @default(0)
  requestsApproved Int      @default(0)
  contactsCreated  Int      @default(0)
  updatedAt        DateTime @updatedAt
  persona          Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model Identity {
  id                                String                         @id @default(uuid()) @db.Uuid
  personId                          String?                        @db.Uuid
  identityType                      IdentityType
  displayName                       String                         @db.VarChar(160)
  handle                            String?                        @unique @db.VarChar(80)
  verificationLevel                 String                         @db.VarChar(64)
  status                            String                         @db.VarChar(64)
  metadataJson                      Json?
  createdAt                         DateTime                       @default(now())
  updatedAt                         DateTime                       @updatedAt
  outgoingConnections               IdentityConnection[]           @relation("IdentityConnectionSource")
  incomingConnections               IdentityConnection[]           @relation("IdentityConnectionTarget")
  createdConnections                IdentityConnection[]           @relation("IdentityConnectionCreatedBy")
  outgoingConversations             IdentityConversation[]         @relation("IdentityConversationSource")
  incomingConversations             IdentityConversation[]         @relation("IdentityConversationTarget")
  createdConversations              IdentityConversation[]         @relation("IdentityConversationCreatedBy")
  createdPermissionOverrides        ConnectionPermissionOverride[] @relation("ConnectionPermissionOverrideCreatedBy")
  targetedContentAccessRules        ContentAccessRule[]            @relation("ContentAccessRuleTarget")
  createdContentAccessRules         ContentAccessRule[]            @relation("ContentAccessRuleCreatedBy")
  personas                          Persona[]
  members                           IdentityMember[]
  operators                         IdentityOperator[]

  @@index([identityType])
  @@index([personId])
}

enum IdentityMemberRole {
  MEMBER
  MANAGER
  OWNER
}

enum IdentityMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

model IdentityMember {
  id          String               @id @default(uuid()) @db.Uuid
  identityId  String               @db.Uuid
  personId    String               @db.Uuid
  role        IdentityMemberRole
  status      IdentityMemberStatus @default(INVITED)
  metadataJson Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  identity    Identity             @relation(fields: [identityId], references: [id], onDelete: Cascade)
  personaAssignments IdentityMemberPersonaAssignment[]

  @@unique([identityId, personId])
  @@index([identityId])
  @@index([personId])
  @@index([status])
}

model IdentityMemberPersonaAssignment {
  id               String         @id @default(uuid()) @db.Uuid
  identityMemberId String         @db.Uuid
  personaId        String         @db.Uuid
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  identityMember   IdentityMember @relation(fields: [identityMemberId], references: [id], onDelete: Cascade)
  persona          Persona        @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([identityMemberId, personaId])
  @@index([identityMemberId])
  @@index([personaId])
}

enum IdentityOperatorRole {
  OPERATOR
  ADMIN
  SUPER_ADMIN
}

enum IdentityOperatorStatus {
  ACTIVE
  INVITED
  REVOKED
}

model IdentityOperator {
  id            String                 @id @default(uuid()) @db.Uuid
  identityId    String                 @db.Uuid
  personId      String                 @db.Uuid
  role          IdentityOperatorRole
  status        IdentityOperatorStatus @default(INVITED)
  permissionsJson Json?
  metadataJson   Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  identity      Identity               @relation(fields: [identityId], references: [id], onDelete: Cascade)
  personaAssignments IdentityOperatorPersonaAssignment[]

  @@unique([identityId, personId])
  @@index([identityId])
  @@index([personId])
  @@index([status])
}

model IdentityOperatorPersonaAssignment {
  id                 String           @id @default(uuid()) @db.Uuid
  identityOperatorId String           @db.Uuid
  personaId          String           @db.Uuid
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  identityOperator   IdentityOperator @relation(fields: [identityOperatorId], references: [id], onDelete: Cascade)
  persona            Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([identityOperatorId, personaId])
  @@index([identityOperatorId])
  @@index([personaId])
}

model IdentityConnection {
  id                    String                         @id @default(uuid()) @db.Uuid
  sourceIdentityId      String                         @db.Uuid
  targetIdentityId      String                         @db.Uuid
  connectionType        ConnectionType
  relationshipType      RelationshipType?
  trustState            TrustState
  status                ConnectionStatus
  createdByIdentityId   String                         @db.Uuid
  note                  String?                        @db.VarChar(500)
  metadataJson          Json?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  sourceIdentity        Identity                       @relation("IdentityConnectionSource", fields: [sourceIdentityId], references: [id], onDelete: Cascade)
  targetIdentity        Identity                       @relation("IdentityConnectionTarget", fields: [targetIdentityId], references: [id], onDelete: Cascade)
  createdByIdentity     Identity                       @relation("IdentityConnectionCreatedBy", fields: [createdByIdentityId], references: [id], onDelete: Cascade)
  conversations         IdentityConversation[]
  permissionOverrides   ConnectionPermissionOverride[]
  permissionSnapshots   ConnectionPermissionSnapshot[]

  @@unique([sourceIdentityId, targetIdentityId])
  @@index([sourceIdentityId])
  @@index([targetIdentityId])
  @@index([connectionType])
  @@index([relationshipType])
  @@index([trustState])
  @@index([status])
  @@index([sourceIdentityId, status])
  @@index([targetIdentityId, status])
}

model ConnectionPermissionOverride {
  id                  String             @id @default(uuid()) @db.Uuid
  connectionId        String             @db.Uuid
  permissionKey       String             @db.VarChar(120)
  effect              PermissionEffect
  limitsJson          Json?
  reason              String?            @db.VarChar(280)
  createdByIdentityId String             @db.Uuid
  createdAt           DateTime           @default(now())
  connection          IdentityConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  createdByIdentity   Identity           @relation("ConnectionPermissionOverrideCreatedBy", fields: [createdByIdentityId], references: [id], onDelete: Cascade)

  @@unique([connectionId, permissionKey])
}

model ConnectionPermissionSnapshot {
  id              String             @id @default(uuid()) @db.Uuid
  connectionId    String             @db.Uuid
  policyVersion   Int
  permissionsJson Json
  metadataJson    Json?
  computedAt      DateTime
  connection      IdentityConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([connectionId, policyVersion])
}

model ContentAccessRule {
  id                  String   @id @default(uuid()) @db.Uuid
  contentId           String   @db.Uuid
  targetIdentityId    String   @db.Uuid
  canView             Boolean  @default(false)
  canDownload         Boolean  @default(false)
  canForward          Boolean  @default(false)
  canExport           Boolean  @default(false)
  screenshotPolicy    String   @default("INHERIT") @db.VarChar(16)
  recordPolicy        String   @default("INHERIT") @db.VarChar(16)
  expiryAt            DateTime?
  viewLimit           Int?
  watermarkMode       String?  @db.VarChar(64)
  aiAccessAllowed     Boolean?
  metadataJson        Json?
  createdByIdentityId String   @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  targetIdentity      Identity @relation("ContentAccessRuleTarget", fields: [targetIdentityId], references: [id], onDelete: Cascade)
  createdByIdentity   Identity @relation("ContentAccessRuleCreatedBy", fields: [createdByIdentityId], references: [id], onDelete: Cascade)

  @@unique([contentId, targetIdentityId])
  @@index([contentId])
  @@index([targetIdentityId])
  @@index([expiryAt])
  @@index([contentId, targetIdentityId])
}

model IdentityConversation {
  id                  String             @id @default(uuid()) @db.Uuid
  sourceIdentityId    String             @db.Uuid
  targetIdentityId    String             @db.Uuid
  connectionId        String             @db.Uuid
  personaId           String?            @db.Uuid
  conversationType    String             @db.VarChar(32)
  status              String             @db.VarChar(32)
  title               String?            @db.VarChar(160)
  metadataJson        Json?
  lastResolvedAt      DateTime?
  lastPermissionHash  String?            @db.VarChar(128)
  createdByIdentityId String             @db.Uuid
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  sourceIdentity      Identity           @relation("IdentityConversationSource", fields: [sourceIdentityId], references: [id], onDelete: Cascade)
  targetIdentity      Identity           @relation("IdentityConversationTarget", fields: [targetIdentityId], references: [id], onDelete: Cascade)
  connection          IdentityConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  createdByIdentity   Identity           @relation("IdentityConversationCreatedBy", fields: [createdByIdentityId], references: [id], onDelete: Cascade)
  persona             Persona?           @relation(fields: [personaId], references: [id], onDelete: SetNull)

  @@index([sourceIdentityId, targetIdentityId, connectionId])
  @@unique([sourceIdentityId, targetIdentityId, connectionId, personaId])
  @@index([sourceIdentityId])
  @@index([targetIdentityId])
  @@index([connectionId])
  @@index([personaId])
  @@index([status])
  @@index([conversationType])
  @@index([sourceIdentityId, status])
  @@index([targetIdentityId, status])
}

model ConnectionPolicyTemplate {
  id                 String        @id @default(uuid()) @db.Uuid
  sourceIdentityType IdentityType?
  connectionType     ConnectionType
  templateKey        String        @unique @db.VarChar(120)
  displayName        String        @db.VarChar(160)
  description        String?       @db.Text
  policyVersion      Int           @default(1)
  permissionsJson    Json
  limitsJson         Json?
  isSystem           Boolean       @default(true)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([sourceIdentityType])
  @@index([connectionType])
  @@index([isActive])
  @@index([sourceIdentityType, connectionType, isActive])
}
