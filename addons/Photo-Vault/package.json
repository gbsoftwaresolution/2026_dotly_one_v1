{
  "name": "booster-vault-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Booster Vault - Zero-knowledge photo vault monorepo",
  "keywords": [],
  "author": "Booster Vault Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "node scripts/dev.mjs",
    "web:analyze": "pnpm --filter @booster-vault/web build:analyze",
    "worker": "pnpm --filter @booster-vault/api dev:worker",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "format": "pnpm -r format",
    "type-check": "pnpm -r type-check",
    "openapi:drift": "node scripts/openapi-drift-audit.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:serve": "node scripts/e2e-serve.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
