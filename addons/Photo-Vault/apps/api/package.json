{
  "name": "@booster-vault/api",
  "version": "0.0.1",
  "private": true,
  "description": "Booster Vault REST API (NestJS)",
  "keywords": [],
  "author": "Booster Vault Team",
  "license": "UNLICENSED",
  "main": "dist/apps/api/src/main.js",
  "scripts": {
    "build": "nest build",
    "clean": "rm -rf dist",
    "dev": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --watch --entryFile apps/api/src/main",
    "dev:worker": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --watch --entryFile apps/api/src/worker-main",
    "worker": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --entryFile apps/api/src/worker-main",
    "start": "pnpm start:prod",
    "start:dev": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --watch --entryFile apps/api/src/main",
    "start:e2e": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --entryFile apps/api/src/main",
    "start:debug": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --debug --watch --entryFile apps/api/src/main",
    "start:prod": "node dist/apps/api/src/main",
    "start:worker": "node dist/apps/api/src/worker-main",
    "lint": "eslint --config eslint.config.mjs \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint --config eslint.config.mjs \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "pnpm prisma:generate && tsc --noEmit",
    "type-check:strict:auth": "pnpm prisma:generate && tsc -p tsconfig.strict-auth.json --noEmit",
    "type-check:strict:sharing": "pnpm prisma:generate && tsc -p tsconfig.strict-sharing.json --noEmit",
    "openapi:drift": "node ../../scripts/openapi-drift-audit.mjs",
    "test": "jest && pnpm openapi:drift",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prepare": "pnpm prisma:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/lib-storage": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.983.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "@types/archiver": "^7.0.0",
    "@types/argon2": "^0.15.4",
    "@types/bcrypt": "^6.0.0",
    "@types/passport": "^1.0.17",
    "@types/ua-parser-js": "^0.7.39",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.67.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.9.2",
    "luxon": "^3.7.2",
    "passport": "^0.7.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0",
    "stripe": "^17.2.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@booster-vault/config": "workspace:*",
    "@booster-vault/shared": "workspace:*",
    "@jest/globals": "^30.2.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "@types/yaml": "^1.9.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.0.0",
    "prettier": "^3.2.5",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.0",
    "supertest": "^6.0.0",
    "testcontainers": "^11.11.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0",
    "yaml": "^2.8.2"
  }
}