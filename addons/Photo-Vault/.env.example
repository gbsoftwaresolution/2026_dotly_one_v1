# Booster Vault API Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/booster_vault

# Web UI (for CORS)
WEB_ORIGIN=http://localhost:3000

# Public API origin (used when generating local-dev signed URLs)
# In production behind a reverse proxy, set this to your public API URL.
API_ORIGIN=http://localhost:4000

# Object Storage (S3-compatible) - required for media uploads
#
# DigitalOcean Spaces (recommended):
#   S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#   S3_REGION=us-east-1  # Spaces is S3-compatible; AWS SDK requires a region string
#   S3_BUCKET=<your-space-name>
#   S3_FORCE_PATH_STYLE=false
#
# AWS S3:
#   S3_ENDPOINT=https://s3.amazonaws.com
#   S3_REGION=us-east-1
#
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
SIGNED_URL_TTL_SECONDS=900

# Storage driver behavior:
#   auto  -> use S3 when configured, else local filesystem in development
#   s3    -> force S3 (errors if not configured)
#   local -> force local filesystem (development only)
STORAGE_DRIVER=auto
STORAGE_LOCAL_DIR=.local-storage

# JWT Authentication
JWT_SECRET=change-this-in-production-must-be-32-characters-minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Password Hashing
PASSWORD_HASHING_ALGORITHM=argon2id  # or bcrypt

# Email Configuration
#
# Providers:
#   console -> logs emails to server logs (development)
#   mailgun  -> sends via Mailgun HTTP API
MAILER_PROVIDER=console  # console, mailgun
MAILER_FROM_EMAIL=noreply@boostervault.com

# Mailgun (required when MAILER_PROVIDER=mailgun)
# MAILGUN_BASE_URL defaults to https://api.mailgun.net (US). For EU use https://api.eu.mailgun.net
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_UPLOAD_TTL=60
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_SHARE_PUBLIC_TTL=60
RATE_LIMIT_SHARE_PUBLIC_MAX=30
RATE_LIMIT_CARD_PUBLIC_TTL=60
RATE_LIMIT_CARD_PUBLIC_MAX=30
RATE_LIMIT_CARD_CONTACT_PUBLIC_TTL=300
RATE_LIMIT_CARD_CONTACT_PUBLIC_MAX=5
RATE_LIMIT_CARD_TOKEN_PUBLIC_TTL=300
RATE_LIMIT_CARD_TOKEN_PUBLIC_MAX=20
RATE_LIMIT_BILLING_WEBHOOK_TTL=60
RATE_LIMIT_BILLING_WEBHOOK_MAX=30

# Abuse resistance (CAPTCHA)
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Frontend URLs (for email verification links)
WEB_APP_URL=http://localhost:3000
VERIFICATION_SUCCESS_PATH=/verify-success
VERIFICATION_ERROR_PATH=/verify-error
PASSWORD_RESET_PATH=/reset-password

# Redis / Job Queue (BullMQ)
REDIS_URL=redis://localhost:6379

# Queue concurrency (per worker process)
QUEUE_CONCURRENCY_EXPORTS=2
QUEUE_CONCURRENCY_PURGE=5
QUEUE_CONCURRENCY_THUMBNAILS=5

# Worker heartbeat (written by the worker process to Postgres)
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_HEARTBEAT_STALE_SECONDS=60
WORKER_HEARTBEAT_CLEANUP_INTERVAL_MINUTES=60
WORKER_HEARTBEAT_RETENTION_HOURS=24

# Exports background processing
EXPORT_TTL_DAYS=7
EXPORT_MAX_ACTIVE_JOBS_PER_USER=2
EXPORT_DOWNLOAD_TIMEOUT=300
EXPORT_WORKER_STUCK_THRESHOLD_MINUTES=30
EXPORT_CLEANUP_INTERVAL_HOURS=24
EXPORT_WATCHDOG_INTERVAL_MINUTES=30
DISABLE_EXPORTS=false

# Uploads kill switch
DISABLE_UPLOADS=false

# Purge scan schedule
PURGE_SCAN_INTERVAL_MINUTES=5
PURGE_SCAN_BATCH_SIZE=500

# Thumbnails verification scan schedule
THUMBNAIL_VERIFY_SCAN_INTERVAL_MINUTES=10
THUMBNAIL_VERIFY_SCAN_BATCH_SIZE=500

# Billing & Payments
CRYPTO_PAYMENT_ADDRESS=
CRYPTO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CARD_PROCESSING_FEE_PERCENT=4
BILLING_CURRENCY=USD
